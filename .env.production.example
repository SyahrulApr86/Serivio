# ── Database ──────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER/PASSWORD/DB below
DATABASE_URL=postgres://serivio:CHANGE_ME@serivio-postgres:5432/serivio
POSTGRES_USER=serivio
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=serivio

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_LONG_RANDOM_STRING
# Public URL of your app (no trailing slash)
BETTER_AUTH_URL=https://yourdomain.com

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://serivio-redis:6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=serivio-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=serivio-covers
# Public URL browsers use to load cover images — must be reachable from outside
# If MinIO is behind a reverse proxy: https://yourdomain.com/covers
# If port 9000 is exposed directly: http://YOUR_VPS_IP:9000/serivio-covers
MINIO_PUBLIC_URL=http://YOUR_VPS_IP:9000/serivio-covers
