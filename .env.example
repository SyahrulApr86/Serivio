# Database
DATABASE_URL=postgres://serivio:serivio@localhost:5432/serivio

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=serivio-covers
# Public base URL used to serve uploaded covers
MINIO_PUBLIC_URL=http://localhost:9000/serivio-covers

# AI (OpenAI-compatible). Default provider powers the chatbot; users can switch.
AI_DEFAULT_PROVIDER=deepseek
# GPT / Bluesminds
AI_GPT_BASE_URL=https://api.bluesminds.com/v1
AI_GPT_API_KEY=sk-CHANGE_ME
AI_GPT_MODEL=gpt-5.5
# DeepSeek
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_API_KEY=sk-CHANGE_ME
AI_DEEPSEEK_MODEL=deepseek-chat

# MCP server (standalone process)
MCP_PORT=3001
