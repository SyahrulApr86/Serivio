# Database
DATABASE_URL=postgres://serivio:serivio@localhost:5432/serivio

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=serivio-series

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=serivio-covers
# Public base URL used to serve uploaded covers
MINIO_PUBLIC_URL=http://localhost:9000/serivio-covers
