{
	"name": "serivio",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/lib/server/db/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun run src/lib/server/db/seed.ts",
		"search:reindex": "bun run src/lib/server/search/reindex.ts",
		"test": "vitest run",
		"test:unit": "vitest",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.50.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.1.0",
		"@types/bun": "^1.2.0",
		"drizzle-kit": "^0.31.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.0",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.4.0",
		"prettier-plugin-svelte": "^3.3.0",
		"prettier-plugin-tailwindcss": "^0.6.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.1.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.20.0",
		"vite": "^8.0.16",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"@elastic/elasticsearch": "^8.17.0",
		"@fontsource/manrope": "^5.1.0",
		"@fontsource/noto-serif": "^5.1.0",
		"better-auth": "^1.2.0",
		"drizzle-orm": "^0.39.0",
		"ioredis": "^5.4.0",
		"minio": "^8.0.0",
		"postgres": "^3.4.5",
		"sveltekit-superforms": "^2.22.0",
		"valibot": "^1.0.0"
	}
}
